# Claude Code Credentials Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to ~/.claude/configs/credentials.env and fill in your values.
# That path is git-ignored — NEVER commit your actual credentials.
#
# Usage (in your shell after sourcing profile-functions.sh):
#   cc-kn        → switch to KN identity (Anthropic OAuth)
#   cc-naisaie   → switch to Naisaie identity (Anthropic OAuth)
#   cc-kuze      → switch to Kuze identity (AWS Bedrock)
#   cc-whoami    → show current profile / identity / mode
# ─────────────────────────────────────────────────────────────────────────────

# ─── Anthropic OAuth tokens (cc-kn / cc-naisaie) ────────────────────────────
# Claude Code uses CLAUDE_CODE_OAUTH_TOKEN, not ANTHROPIC_API_KEY
CC_KN_OAUTH_TOKEN=sk-ant-oat01-REPLACE_WITH_KN_TOKEN
CC_KN_NAME=KN

CC_NAISAIE_OAUTH_TOKEN=sk-ant-oat01-REPLACE_WITH_NAISAIE_TOKEN
CC_NAISAIE_NAME=Naisaie

# ─── Bedrock profiles (cc-kuze) ─────────────────────────────────────────────
# Option 1: Use AWS profile (standard authentication)
CC_KUZE_AWS_PROFILE=default
CC_KUZE_AWS_REGION=us-east-1

# Option 2: Use AWS bearer token (takes precedence if set)
# Get your token from AWS console or via: aws bedrock get-bearer-token
CC_KUZE_AWS_BEARER_TOKEN=

CC_KUZE_NAME=Kuze

# ─── Add more identities below ───────────────────────────────────────────────
# Pattern: CC_<NAME>_OAUTH_TOKEN / CC_<NAME>_AWS_PROFILE / CC_<NAME>_NAME
